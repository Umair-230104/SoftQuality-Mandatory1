    {
      "name": "GET /cpr-name-gender-dob",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const data = pm.response.json();",
              "const cpr = String(data.cpr);",
              "const gender = data.gender.toLowerCase();",
              "const dob = data.dateOfBirth;",
              "",
              "pm.test(\"All required fields exist\", function () {",
              "    pm.expect(data.firstName).to.exist;",
              "    pm.expect(data.lastName).to.exist;",
              "    pm.expect(data.gender).to.exist;",
              "    pm.expect(data.dateOfBirth).to.exist;",
              "    pm.expect(data.cpr).to.exist;",
              "});",
              "",
              "pm.test(\"CPR is 10 digits\", function () {",
              "    pm.expect(cpr).to.match(/^\\d{10}$/);",
              "});",
              "",
              "pm.test(\"dateOfBirth is an array with 3 parts\", function () {",
              "    pm.expect(dob).to.be.an(\"array\");",
              "    pm.expect(dob.length).to.eql(3);",
              "});",
              "",
              "pm.test(\"dateOfBirth matches CPR first 6 digits\", function () {",
              "    const cprDD = cpr.substring(0,2);",
              "    const cprMM = cpr.substring(2,4);",
              "    const cprYY = cpr.substring(4,6);",
              "",
              "    const year = String(dob[0]);",
              "    const month = String(dob[1]).padStart(2, \"0\");",
              "    const day = String(dob[2]).padStart(2, \"0\");",
              "    const dobYY = year.slice(-2);",
              "",
              "    pm.expect(day).to.eql(cprDD);",
              "    pm.expect(month).to.eql(cprMM);",
              "    pm.expect(dobYY).to.eql(cprYY);",
              "});",
              "",
              "pm.test(\"CPR last digit matches gender\", function () {",
              "    const lastDigit = parseInt(cpr[cpr.length - 1]);",
              "    if (gender === \"female\") pm.expect(lastDigit % 2).to.eql(0);",
              "    if (gender === \"male\") pm.expect(lastDigit % 2).to.eql(1);",
              "});",
              "",
              "pm.test(\"dateOfBirth is a valid date\", function () {",
              "    const [year, month, day] = dob;",
              "    const d = new Date(year, month - 1, day);",
              "    pm.expect(isNaN(d.getTime())).to.eql(false);",
              "});"
            ]
          }
        }
      ],
