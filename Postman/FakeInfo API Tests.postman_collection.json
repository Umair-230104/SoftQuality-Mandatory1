  "item": [
    {
      "name": "GET /cpr",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response time is under 1000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);",
              "});",
              "",
              "const data = pm.response.json();",
              "const cpr = data.cpr || data;",
              "",
              "pm.test(\"CPR exists\", function () {",
              "    pm.expect(cpr).to.exist;",
              "});",
              "",
              "pm.test(\"CPR has 10 digits\", function () {",
              "    pm.expect(String(cpr)).to.match(/^\\d{10}$/);",
              "});",
              "",
              "pm.test(\"CPR first 6 digits look like ddMMyy\", function () {",
              "    const cprStr = String(cpr);",
              "    const dd = parseInt(cprStr.substring(0,2));",
              "    const mm = parseInt(cprStr.substring(2,4));",
              "    pm.expect(dd).to.be.within(1,31);",
              "    pm.expect(mm).to.be.within(1,12);",
              "});",
              "",
              "pm.test(\"CPR must not contain letters\", function () {",
              "    pm.expect(String(cpr)).to.not.match(/[A-Za-z]/);",
              "});",
              "",
              "pm.test(\"Server should not fail\", function () {",
              "    pm.expect(pm.response.code).to.not.equal(500);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/cpr",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "cpr"
          ]
        }
      },
      "response": []
    },
