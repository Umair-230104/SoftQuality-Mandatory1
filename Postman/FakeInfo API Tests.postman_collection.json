    {
      "name": "GET /cpr-name-gender",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const data = pm.response.json();",
              "const cpr = String(data.cpr);",
              "const gender = data.gender.toLowerCase();",
              "const lastDigit = parseInt(cpr[cpr.length - 1]);",
              "",
              "pm.test(\"CPR and gender exist\", function () {",
              "    pm.expect(cpr).to.match(/^\\d{10}$/);",
              "    pm.expect(gender).to.be.oneOf([\"male\", \"female\"]);",
              "});",
              "",
              "pm.test(\"First and last name exist\", function () {",
              "    pm.expect(data.firstName).to.exist;",
              "    pm.expect(data.lastName).to.exist;",
              "});",
              "",
              "pm.test(\"Names are not empty\", function () {",
              "    pm.expect(data.firstName.trim()).to.not.eql(\"\");",
              "    pm.expect(data.lastName.trim()).to.not.eql(\"\");",
              "});",
              "",
              "pm.test(\"CPR last digit matches gender rule\", function () {",
              "    if (gender === \"female\") {",
              "        pm.expect(lastDigit % 2).to.eql(0);",
              "    } else if (gender === \"male\") {",
              "        pm.expect(lastDigit % 2).to.eql(1);",
              "    }",
              "});",
              "",
              "pm.test(\"CPR must not have wrong length\", function () {",
              "    pm.expect(cpr.length).to.eql(10);",
              "});"
            ]
          }
        }
      ],
