    {
      "name": "GET /phone",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const validPrefixes = [\"2\", \"30\", \"31\", \"40\", \"41\", \"42\", \"50\", \"51\", \"52\", \"53\", \"60\", \"61\", \"71\", \"81\", \"91\", \"92\", \"93\", \"342\", \"344\", \"345\", \"346\", \"347\", \"348\", \"349\", \"356\", \"357\", \"359\", \"362\", \"365\", \"366\", \"389\", \"398\", \"431\", \"441\", \"462\", \"466\", \"468\", \"472\", \"474\", \"476\", \"478\", \"485\", \"486\", \"488\", \"489\", \"493\", \"494\", \"495\", \"496\", \"498\", \"499\", \"542\", \"543\", \"545\", \"551\", \"552\", \"556\", \"571\", \"572\", \"573\", \"574\", \"577\", \"579\", \"584\", \"586\", \"587\", \"589\", \"597\", \"598\", \"627\", \"629\", \"641\", \"649\", \"658\", \"662\", \"663\", \"664\", \"665\", \"667\", \"692\", \"693\", \"694\", \"697\", \"771\", \"772\", \"782\", \"783\", \"785\", \"786\", \"788\", \"789\", \"826\", \"827\", \"829\"];",
              "const data = pm.response.json();",
              "const phone = String(data.phoneNumber || data.phone || data);",
              "",
              "pm.test(\"Phone exists\", function () {",
              "    pm.expect(phone).to.exist;",
              "});",
              "",
              "pm.test(\"Phone has 8 digits\", function () {",
              "    pm.expect(phone).to.match(/^\\d{8}$/);",
              "});",
              "",
              "pm.test(\"Phone starts with valid prefix\", function () {",
              "    const isValid = validPrefixes.some(prefix => phone.startsWith(prefix));",
              "    pm.expect(isValid).to.eql(true);",
              "});",
              "",
              "pm.test(\"Phone must not contain letters or hyphen\", function () {",
              "    pm.expect(phone).to.not.match(/[A-Za-z-]/);",
              "});",
              "",
              "pm.test(\"Phone length must not be shorter or longer than 8\", function () {",
              "    pm.expect(phone.length).to.eql(8);",
              "});"
            ]
          }
        }
      ],
