      "name": "GET /name-gender-dob",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const data = pm.response.json();",
              "",
              "pm.test(\"Fields exist\", function () {",
              "    pm.expect(data.firstName).to.exist;",
              "    pm.expect(data.lastName).to.exist;",
              "    pm.expect(data.gender).to.exist;",
              "    pm.expect(data.dateOfBirth).to.exist;",
              "});",
              "",
              "pm.test(\"dateOfBirth is an array with 3 parts\", function () {",
              "    pm.expect(data.dateOfBirth).to.be.an(\"array\");",
              "    pm.expect(data.dateOfBirth.length).to.eql(3);",
              "});",
              "",
              "pm.test(\"dateOfBirth contains valid year, month, day\", function () {",
              "    const [year, month, day] = data.dateOfBirth;",
              "    pm.expect(year).to.be.a(\"number\");",
              "    pm.expect(month).to.be.within(1, 12);",
              "    pm.expect(day).to.be.within(1, 31);",
              "});",
              "",
              "pm.test(\"dateOfBirth is not in the future\", function () {",
              "    const [year, month, day] = data.dateOfBirth;",
              "    const dob = new Date(year, month - 1, day);",
              "    pm.expect(dob.getTime()).to.be.below(Date.now());",
              "});",
              "",
              "pm.test(\"Gender is valid\", function () {",
              "    pm.expect(data.gender.toLowerCase()).to.be.oneOf([\"male\", \"female\"]);",
              "});"
